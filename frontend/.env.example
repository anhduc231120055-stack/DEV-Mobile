# Optional override.
# If omitted, the app auto-detects the host from the Expo dev server.

# Local backend running on the same machine (web / iOS simulator)
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Android emulator only
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api

# Physical phone on the same Wi-Fi as the backend machine
# EXPO_PUBLIC_API_BASE_URL=http://192.168.10.7:3000/api
